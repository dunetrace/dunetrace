# Copy this file to .env and fill in your values.
# docker compose will load .env automatically.

# ── Shared ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dunetrace:dunetrace@postgres:5432/dunetrace
LOG_LEVEL=INFO

# ── Ingest service ────────────────────────────────────────────────────────────
AUTH_MODE=dev          # dev | prod

# ── Detector service ──────────────────────────────────────────────────────────
POLL_INTERVAL=5        # seconds between detector cycles
STALL_TIMEOUT_SECS=90  # treat runs with no events for N seconds as stalled
BATCH_SIZE=100         # runs processed per cycle

# ── Alerts service (leave blank to run with no destinations) ──────────────────
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_CHANNEL=#agent-alerts
# SLACK_MIN_SEVERITY=HIGH           # LOW | MEDIUM | HIGH | CRITICAL
# WEBHOOK_URL=https://your-endpoint.example.com/alerts
# WEBHOOK_SECRET=your-hmac-secret

# ── SDK examples (optional) ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
