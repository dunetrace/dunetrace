# Copy this file to .env and fill in your values.
# docker compose will load .env automatically.

# Shared
DATABASE_URL=postgresql://dunetrace:dunetrace@postgres:5432/dunetrace
LOG_LEVEL=INFO

# Ingest service
# AUTH_MODE: dev (no API key needed) | prod (requires api_keys table entries)
AUTH_MODE=dev

# Detector service
# Seconds between detector poll cycles
POLL_INTERVAL=5
# Treat runs with no new events for N seconds as stalled
STALL_TIMEOUT_SECS=90
# Runs processed per poll cycle
BATCH_SIZE=100

# Alerts service (leave blank to run with no destinations)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
# SLACK_CHANNEL=#agent-alerts
# SLACK_MIN_SEVERITY=HIGH           # LOW | MEDIUM | HIGH | CRITICAL
# WEBHOOK_URL=https://your-endpoint.example.com/alerts
# WEBHOOK_SECRET=your-hmac-secret

# SDK examples (optional)
# OPENAI_API_KEY=sk-...
